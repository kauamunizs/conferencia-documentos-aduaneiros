# MOCK_MODE=true => o backend NUNCA chama a API da Anthropic. Os campos
# extraídos são valores fixos (não refletem os documentos enviados de
# verdade), mas todo o resto do pipeline roda normalmente: OCR local,
# comparação, localização de bounding box e a interface completa.
# Para usar a extração real (paga), troque para MOCK_MODE=false e preencha
# ANTHROPIC_API_KEY com uma chave de verdade.
MOCK_MODE=true

ANTHROPIC_API_KEY=sk-ant-...
FRONTEND_ORIGIN=http://localhost:3000

# Só necessário no Windows, quando Tesseract/Poppler não ficam no PATH do sistema.
# Em Linux/produção normalmente não é preciso definir nada disso.
# TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe
# TESSDATA_PREFIX=C:\caminho\para\projetod\backend\tessdata
# POPPLER_PATH=C:\caminho\para\poppler\Library\bin
